LOG_LEVEL=INFO

# Public URLs
WEBAPP_URL=https://app.example.com
VITE_API_BASE_URL=https://api.example.com
VITE_TELEGRAM_BOT_URL=https://t.me/your_bot_username
VITE_SUPPORT_TELEGRAM_URL=https://t.me/your_support_group

# Bot
BOT_TOKEN=replace_with_real_bot_token
BOT_USERNAME=your_bot_username
BOT_USE_WEBHOOK=true
BOT_WEBHOOK_BASE_URL=https://api.example.com
BOT_WEBHOOK_PATH=/bot/webhook
BOT_WEBHOOK_SECRET=replace_with_random_webhook_secret
BOT_WEB_SERVER_HOST=0.0.0.0
BOT_WEB_SERVER_PORT=8080
API_URL=http://api:8000
# Shared secret for internal bot -> api callbacks, including Telegram Stars pre-checkout/finalization.
API_TOKEN=replace_with_internal_api_token

# Database and cache
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/remnastore
POSTGRES_DB=remnastore
POSTGRES_USER=user
POSTGRES_PASSWORD=password
REDIS_URL=redis://redis:6379/0
SUPABASE_USER_CACHE_TTL_SECONDS=300
AUTH_TOKEN_CACHE_TTL_SECONDS=300
ACCOUNT_RESPONSE_CACHE_TTL_SECONDS=60

# Payments maintenance
PAYMENT_PENDING_TTL_SECONDS_YOOKASSA=3600
PAYMENT_PENDING_TTL_SECONDS_TELEGRAM_STARS=900
PAYMENT_EXPIRE_STALE_INTERVAL_SECONDS=60
PAYMENT_RECONCILE_YOOKASSA_INTERVAL_SECONDS=120
PAYMENT_RECONCILE_YOOKASSA_MIN_AGE_SECONDS=180
PAYMENT_JOBS_BATCH_SIZE=100
PAYMENT_JOB_LOCK_TTL_SECONDS=60

# Notifications maintenance
NOTIFICATION_TELEGRAM_DELIVERY_INTERVAL_SECONDS=30
NOTIFICATION_JOBS_BATCH_SIZE=100
NOTIFICATION_JOB_LOCK_TTL_SECONDS=60
NOTIFICATION_TELEGRAM_MAX_ATTEMPTS=5
NOTIFICATION_TELEGRAM_RETRY_BASE_SECONDS=30
NOTIFICATION_TELEGRAM_RETRY_MAX_SECONDS=900

# Auth
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
TELEGRAM_INIT_DATA_TTL_SECONDS=600
# AuthAdmin
ADMIN_JWT_ACCESS_TOKEN_EXPIRES_SECONDS=43200
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace_with_initial_admin_password
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_FULL_NAME=Remnastore Admin

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# Remnawave
REMNAWAVE_API_URL=https://remnawave.example.com
REMNAWAVE_API_TOKEN=replace_with_remnawave_token
REMNAWAVE_WEBHOOK_SECRET=replace_with_remnawave_webhook_secret
REMNAWAVE_USERNAME_PREFIX=remna
REMNAWAVE_USER_LABEL=RemnaStore
#REMNAWAVE_DEFAULT_INTERNAL_SQUAD_UUID=
#REMNAWAVE_DEFAULT_INTERNAL_SQUAD_NAME=
TRIAL_DURATION_DAYS=3
MIN_WITHDRAWAL_AMOUNT_RUB=300

# YooKassa
YOOKASSA_SHOP_ID=replace_with_yookassa_shop_id
YOOKASSA_SECRET_KEY=replace_with_yookassa_secret_key
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_VERIFY_TLS=true
