# Логирование: общие настройки API, бота и Python worker-ов.
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_DIR=./.logs
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5
ACCESS_LOG_ENABLED=true

# Docker images: можно зафиксировать конкретные теги из Docker Hub.
DOCKERHUB_REPOSITORY=masteryodaofficial/remnastorepy
API_IMAGE_TAG=api-latest
BOT_IMAGE_TAG=bot-latest
WEB_IMAGE_TAG=web-latest
ADMIN_IMAGE_TAG=admin-latest

# Публичные URL: адреса, которые видит браузер и Telegram.
# Для web/admin они читаются из runtime-config.js при старте контейнера.
WEBAPP_URL=https://web.example.com
VITE_API_BASE_URL=https://api.example.com
VITE_WEB_BRAND_NAME=QuickCloud
VITE_TELEGRAM_BOT_URL=https://t.me/your_bot_username
VITE_SUPPORT_TELEGRAM_URL=https://t.me/your_support_group
# Опционально: same-origin fallback для Telegram Mini App SDK.
VITE_TELEGRAM_WEB_APP_FALLBACK_URL=/vendor/telegram-web-app.js

# Telegram Bot: webhook и внутренние bot -> api callback-и.
BOT_TOKEN=replace_with_real_bot_token
BOT_USERNAME=your_bot_username
BOT_USE_WEBHOOK=true
BOT_WEBHOOK_BASE_URL=https://bot.example.com
BOT_WEBHOOK_PATH=/bot/webhook
BOT_WEBHOOK_SECRET=replace_with_random_webhook_secret
BOT_WEBHOOK_IP_ADDRESS=
# Если параметры ниже оставить закомментированными, используются встроенные значения из кода.
# BOT_WEBHOOK_SETUP_MAX_ATTEMPTS=5
# BOT_WEBHOOK_SETUP_TIMEOUT_SECONDS=20
# BOT_WEBHOOK_FALLBACK_TO_POLLING=true
BOT_WEB_SERVER_HOST=0.0.0.0
BOT_WEB_SERVER_PORT=8080
API_URL=http://api:8000
API_TOKEN=replace_with_internal_api_token

# Хранилища и базовые API настройки.
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/remnastore
POSTGRES_DB=remnastore
POSTGRES_USER=user
POSTGRES_PASSWORD=password
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600
ADMIN_JWT_ACCESS_TOKEN_EXPIRES_SECONDS=43200
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace_with_initial_admin_password
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_FULL_NAME=Remnastore Admin
TELEGRAM_INIT_DATA_TTL_SECONDS=600

# Supabase backend: серверная проверка access token-ов.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
SUPABASE_USER_CACHE_TTL_SECONDS=300
AUTH_TOKEN_CACHE_TTL_SECONDS=300
ACCOUNT_RESPONSE_CACHE_TTL_SECONDS=60

# Supabase frontend: должны указывать на тот же проект, что и backend.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_key

# Бизнес-правила.
# Длительность платных тарифов задается в apps/api/app/config/subscription-plans.json.
TRIAL_DURATION_DAYS=3
# Если параметры ниже оставить закомментированными, используются встроенные лимиты из кода.
# TRIAL_TRAFFIC_LIMIT_GB=10
# TRIAL_TRAFFIC_LIMIT_STRATEGY=WEEK
# TRIAL_DEVICE_LIMIT=3
# DEFAULT_SUBSCRIPTION_DEVICE_LIMIT=3
DEFAULT_REFERRAL_REWARD_RATE=20
MIN_WITHDRAWAL_AMOUNT_RUB=300
SUBSCRIPTION_ACTIVATION_NO_CONNECTION_GRACE_SECONDS=900

# Remnawave: доступ к панели и правила создания пользователей.
REMNAWAVE_API_URL=https://remnawave.example.com
REMNAWAVE_API_TOKEN=replace_with_remnawave_token
REMNAWAVE_WEBHOOK_SECRET=replace_with_remnawave_webhook_secret
REMNAWAVE_USERNAME_PREFIX=remna
REMNAWAVE_USER_LABEL=RemnaStore
# REMNAWAVE_DEFAULT_INTERNAL_SQUAD_UUID=
# REMNAWAVE_DEFAULT_INTERNAL_SQUAD_NAME=

# YooKassa: прием RUB-платежей.
YOOKASSA_SHOP_ID=replace_with_yookassa_shop_id
YOOKASSA_SECRET_KEY=replace_with_yookassa_secret_key
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_VERIFY_TLS=true

# Платежные фоновые задачи.
PAYMENT_PENDING_TTL_SECONDS_YOOKASSA=3600
PAYMENT_PENDING_TTL_SECONDS_TELEGRAM_STARS=900
PAYMENT_EXPIRE_STALE_INTERVAL_SECONDS=60
PAYMENT_RECONCILE_YOOKASSA_INTERVAL_SECONDS=120
PAYMENT_RECONCILE_WALLET_GRANTS_INTERVAL_SECONDS=60
PAYMENT_RECONCILE_YOOKASSA_MIN_AGE_SECONDS=180
PAYMENT_JOBS_BATCH_SIZE=100
PAYMENT_JOB_LOCK_TTL_SECONDS=60

# Уведомления.
NOTIFICATION_TELEGRAM_DELIVERY_INTERVAL_SECONDS=30
NOTIFICATION_JOBS_BATCH_SIZE=100
NOTIFICATION_JOB_LOCK_TTL_SECONDS=60
NOTIFICATION_TELEGRAM_MAX_ATTEMPTS=5
NOTIFICATION_TELEGRAM_RETRY_BASE_SECONDS=30
NOTIFICATION_TELEGRAM_RETRY_MAX_SECONDS=900

# Рассылки.
BROADCAST_TIMEZONE=Europe/Moscow
BROADCAST_SCHEDULER_INTERVAL_SECONDS=15
BROADCAST_DELIVERY_INTERVAL_SECONDS=5
BROADCAST_JOBS_BATCH_SIZE=100
BROADCAST_JOB_LOCK_TTL_SECONDS=60
BROADCAST_TELEGRAM_MAX_ATTEMPTS=3
BROADCAST_TELEGRAM_RETRY_BASE_SECONDS=30
BROADCAST_TELEGRAM_RETRY_MAX_SECONDS=900

# API сейчас запускается одним uvicorn-процессом на контейнер.
