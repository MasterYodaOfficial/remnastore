ENV=local
LOG_LEVEL=INFO

# API
API_BASE_URL=http://api:8000

# Bot
# Used both by bot runtime and by API Telegram init-data validation
BOT_TOKEN=replace_me
BOT_ADMIN_IDS=123456789,987654321
BOT_USE_WEBHOOK=false
BOT_WEBHOOK_BASE_URL=https://your-domain.example
BOT_WEBHOOK_PATH=/bot/webhook
BOT_WEBHOOK_SECRET=replace_me
BOT_WEB_SERVER_HOST=0.0.0.0
BOT_WEB_SERVER_PORT=8080

# WebApp
WEBAPP_URL=http://localhost:5173
VITE_API_BASE_URL=http://api:8000
VITE_TELEGRAM_BOT_URL=https://t.me/your_bot_username

# Database
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/remnastore

# Redis
REDIS_URL=redis://localhost:6379/0
SUPABASE_USER_CACHE_TTL_SECONDS=300
AUTH_TOKEN_CACHE_TTL_SECONDS=300
ACCOUNT_RESPONSE_CACHE_TTL_SECONDS=60

# Remnawave
REMNAWAVE_API_URL=http://localhost:3000
REMNAWAVE_API_TOKEN=replace_me

# Auth
JWT_SECRET=change_me
JWT_ACCESS_TOKEN_EXPIRES_SECONDS=3600
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace_me

# Telegram
TELEGRAM_INIT_DATA_TTL_SECONDS=600

# Web Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace_me
